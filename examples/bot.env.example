# Пример конфигурации бота
# Скопируйте этот файл в /root/bot/.env и заполните своими значениями

# ============================================================
# ОСНОВНЫЕ НАСТРОЙКИ БОТА
# ============================================================

# Токен бота от @BotFather
BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrsTUVwxyz

# Telegram ID администраторов (через запятую)
ADMIN_IDS=123456789,987654321

# ============================================================
# ВЕБ-СЕРВЕР И CABINET API
# ============================================================

# Включить веб-сервер (обязательно для кабинета)
WEB_API_ENABLED=true

# Включить Cabinet API
CABINET_ENABLED=true

# Домен кабинета (для CORS)
CABINET_ALLOWED_ORIGINS=https://cabinet.example.com

# JWT секрет для кабинета (сгенерируйте: openssl rand -hex 32)
CABINET_JWT_SECRET=your_jwt_secret_here_32_chars_minimum

# ============================================================
# REMNAWAVE API
# ============================================================

# URL панели Remnawave
REMNAWAVE_API_URL=https://your-remnawave-panel.com

# API ключ панели Remnawave
REMNAWAVE_API_KEY=your_remnawave_api_key_here

# ============================================================
# ДОПОЛНИТЕЛЬНЫЕ НАСТРОЙКИ
# ============================================================

# Язык бота (ru, en)
BOT_LANGUAGE=ru

# Включить логирование
DEBUG=false

# База данных (если используется)
# DATABASE_URL=postgresql://user:password@localhost:5432/dbname
