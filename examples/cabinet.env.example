# Пример конфигурации кабинета
# Скопируйте этот файл в /root/cabinet/.env и заполните своими значениями

# ============================================================
# НАСТРОЙКИ КАБИНЕТА
# ============================================================

# Username бота без @
VITE_TELEGRAM_BOT_USERNAME=your_bot_username

# Путь к API (по умолчанию /api)
VITE_API_URL=/api

# Название приложения в шапке
VITE_APP_NAME=Cabinet

# ============================================================
# ДОПОЛНИТЕЛЬНЫЕ НАСТРОЙКИ
# ============================================================

# Язык интерфейса (ru, en)
# VITE_LOCALE=ru

# Тема по умолчанию (light, dark)
# VITE_DEFAULT_THEME=light
